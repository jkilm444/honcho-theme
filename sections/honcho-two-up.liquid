<style>
  .hn-twoup {
    padding: 120px var(--page-gutter) 0;
  }

  .hn-twoup__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 8px;
  }

  .hn-twoup__sublabel {
    opacity: 0.45;
  }

  .hn-twoup__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }

  .hn-twoup__cell {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    background: #e8e6e1;
    display: block;
  }

  .hn-twoup__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow, 600ms) ease;
  }

  .hn-twoup__cell:hover .hn-twoup__img {
    transform: scale(1.03);
  }

  .hn-twoup__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 28px;
    z-index: 2;
    pointer-events: none;
  }

  .hn-twoup__product-name {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 900;
    font-size: clamp(28px, 3.5vw, 44px);
    line-height: 0.92;
    letter-spacing: var(--tracking-display, -0.03em);
    color: #fff;
    mix-blend-mode: difference;
  }

  @media screen and (max-width: 749px) {
    .hn-twoup {
      padding-top: 72px;
    }

    .hn-twoup__grid {
      gap: 6px;
    }

    .hn-twoup__product-name {
      font-size: clamp(22px, 6vw, 32px);
    }
  }
</style>

<div class="hn-twoup">
  {%- if section.settings.label != blank or section.settings.sublabel != blank -%}
    <div class="hn-twoup__header hn-reveal">
      <span class="hn-label">{{ section.settings.label }}</span>
      {%- if section.settings.sublabel != blank -%}
        <span class="hn-label hn-twoup__sublabel">{{ section.settings.sublabel }}</span>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="hn-twoup__grid">
    {%- if section.settings.product_left != blank -%}
      <a
        href="{{ section.settings.product_left.url }}"
        class="hn-twoup__cell hn-reveal"
        style="--animation-order: 0;"
        aria-label="{{ section.settings.product_left.title | escape }}"
      >
        {%- if section.settings.product_left.featured_media != blank -%}
          {{ section.settings.product_left.featured_media | image_url: width: 1200 | image_tag:
            class: 'hn-twoup__img',
            loading: 'lazy',
            widths: '600,900,1200',
            sizes: '(min-width: 750px) 50vw, 100vw',
            alt: section.settings.product_left.featured_media.alt | default: section.settings.product_left.title
          }}
        {%- endif -%}
        <div class="hn-twoup__overlay">
          <span class="hn-twoup__product-name">{{ section.settings.product_left.title }}</span>
        </div>
      </a>
    {%- else -%}
      <div class="hn-twoup__cell" style="background: #d8d5d0;">
        {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        <div class="hn-twoup__overlay">
          <span class="hn-twoup__product-name">Select product</span>
        </div>
      </div>
    {%- endif -%}

    {%- if section.settings.product_right != blank -%}
      <a
        href="{{ section.settings.product_right.url }}"
        class="hn-twoup__cell hn-reveal"
        style="--animation-order: 1;"
        aria-label="{{ section.settings.product_right.title | escape }}"
      >
        {%- if section.settings.product_right.featured_media != blank -%}
          {{ section.settings.product_right.featured_media | image_url: width: 1200 | image_tag:
            class: 'hn-twoup__img',
            loading: 'lazy',
            widths: '600,900,1200',
            sizes: '(min-width: 750px) 50vw, 100vw',
            alt: section.settings.product_right.featured_media.alt | default: section.settings.product_right.title
          }}
        {%- endif -%}
        <div class="hn-twoup__overlay">
          <span class="hn-twoup__product-name">{{ section.settings.product_right.title }}</span>
        </div>
      </a>
    {%- else -%}
      <div class="hn-twoup__cell" style="background: #c8c5c0;">
        {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
        <div class="hn-twoup__overlay">
          <span class="hn-twoup__product-name">Select product</span>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Honchō Two-Up",
  "tag": "section",
  "class": "honcho-two-up",
  "settings": [
    {
      "type": "product",
      "id": "product_left",
      "label": "Left product"
    },
    {
      "type": "product",
      "id": "product_right",
      "label": "Right product"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Also in rotation"
    },
    {
      "type": "text",
      "id": "sublabel",
      "label": "Sub-label",
      "default": "Batch 02"
    }
  ],
  "presets": [
    {
      "name": "Honchō Two-Up",
      "settings": {
        "label": "Also in rotation",
        "sublabel": "Batch 02"
      }
    }
  ]
}
{% endschema %}
