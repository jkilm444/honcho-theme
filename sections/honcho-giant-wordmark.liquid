<style>
  .hn-giant-wordmark {
    text-align: center;
  }

  .hn-giant-wordmark__img {
    width: min(96vw, 1800px);
    height: auto;
    display: inline-block;
  }

  .hn-giant-wordmark__text {
    display: inline-block;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 900;
    font-size: clamp(60px, 12vw, 200px);
    line-height: 0.9;
    letter-spacing: var(--tracking-display, -0.03em);
    color: var(--honcho-black, #000);
  }
</style>

{%- style -%}
  #shopify-section-{{ section.id }} .hn-giant-wordmark {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: var(--page-gutter);
    padding-right: var(--page-gutter);
  }
{%- endstyle -%}

<div class="hn-giant-wordmark">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2400 | image_tag:
      class: 'hn-giant-wordmark__img',
      loading: 'lazy',
      widths: '600,900,1200,1800,2400',
      sizes: '96vw',
      alt: section.settings.image.alt | default: shop.name
    }}
  {%- else -%}
    <img
      src="{{ 'honcho-athletic-wordmark.png' | asset_url }}"
      class="hn-giant-wordmark__img"
      loading="lazy"
      alt="{{ shop.name }}"
    >
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Honchō Giant Wordmark",
  "tag": "section",
  "class": "honcho-giant-wordmark",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Wordmark image"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 8,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Honchō Giant Wordmark",
      "settings": {
        "padding_top": 80,
        "padding_bottom": 80
      }
    }
  ]
}
{% endschema %}
