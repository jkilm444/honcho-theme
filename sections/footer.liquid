{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

<style>
  .hn-footer {
    border-top: 1px solid #000;
    padding: 60px var(--page-gutter, 24px) 80px;
  }

  .hn-footer__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 48px;
    align-items: start;
  }

  .hn-footer__col-heading {
    opacity: 0.45;
    margin-bottom: 16px;
  }

  .hn-footer__brand-name {
    margin-bottom: 16px;
  }

  .hn-footer__brand-statement {
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.6;
    opacity: 0.6;
    max-width: 240px;
  }

  .hn-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .hn-footer__link {
    font-family: var(--font-body);
    font-size: 12px;
    opacity: 0.65;
    transition: opacity 180ms ease;
  }

  .hn-footer__link:hover {
    opacity: 1;
  }

  .hn-footer__text-content {
    font-size: 12px;
    line-height: 1.6;
    opacity: 0.65;
  }

  .hn-footer__social {
    margin-top: 20px;
  }

  .hn-footer__newsletter {
    margin-top: 48px;
  }

  .hn-footer__newsletter-inner {
    padding: 32px 0;
    display: flex;
    align-items: center;
    gap: 48px;
  }

  .hn-footer__newsletter-heading {
    white-space: nowrap;
    opacity: 0.45;
  }

  .hn-footer__newsletter-field {
    display: flex;
    flex: 1;
    max-width: 400px;
    border-bottom: 1px solid #000;
  }

  .hn-footer__newsletter-input {
    flex: 1;
    border: none;
    background: transparent;
    font-family: var(--font-body);
    font-size: 12px;
    padding: 8px 0;
    outline: none;
  }

  .hn-footer__newsletter-input::placeholder {
    opacity: 0.4;
  }

  .hn-footer__newsletter-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 8px 0 8px 16px;
    opacity: 0.6;
    transition: opacity 180ms ease;
  }

  .hn-footer__newsletter-btn:hover {
    opacity: 1;
  }

  .hn-footer__newsletter-success {
    opacity: 0.55;
    margin-top: 8px;
  }

  .hn-footer__bottom {
    margin-top: 48px;
  }

  .hn-footer__bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 24px;
    flex-wrap: wrap;
  }

  .hn-footer__copyright {
    opacity: 0.4;
  }

  .hn-footer__payment {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    padding: 0;
    margin: 0;
    opacity: 0.5;
  }

  .hn-footer__payment .icon {
    height: 18px;
    width: auto;
  }

  .hn-footer__policies {
    display: flex;
    align-items: center;
    gap: 16px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hn-footer__policy-link {
    opacity: 0.4;
    transition: opacity 180ms ease;
  }

  .hn-footer__policy-link:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 989px) {
    .hn-footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 40px;
    }

    .hn-footer__newsletter-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 16px;
    }

    .hn-footer__newsletter-field {
      width: 100%;
      max-width: none;
    }
  }

  @media screen and (max-width: 749px) {
    .hn-footer__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .hn-footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>

<footer class="hn-footer">
  {%- liquid
    assign has_social_icons = true
    if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
      assign has_social_icons = false
    endif
  -%}
  <!-- Main grid: brand col + up to 4 link cols -->
  <div class="hn-footer__grid">
    <!-- Col 1: brand statement -->
    <div class="hn-footer__col hn-footer__col--brand">
      <p class="hn-label hn-footer__brand-name">Honchō Athletic</p>
      <p class="hn-footer__brand-statement">
        Built for competitors. Worn by commanders. Engineered in Japan, issued worldwide. No shortcuts. No compromises. Standard or nothing.
      </p>
      {%- if section.settings.show_social and has_social_icons -%}
        {%- render 'social-icons', class: 'hn-footer__social' -%}
      {%- endif -%}
    </div>

    <!-- Cols 2–5: link_list and text blocks -->
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'link_list' -%}
          <div class="hn-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <p class="hn-label-sm hn-footer__col-heading">{{ block.settings.heading | escape }}</p>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="hn-footer__links">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="hn-footer__link">{{ link.title | escape }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- when 'text' -%}
          <div class="hn-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <p class="hn-label-sm hn-footer__col-heading">{{ block.settings.heading | escape }}</p>
            {%- endif -%}
            <div class="hn-footer__text-content rte">{{ block.settings.subtext }}</div>
          </div>
        {%- when '@app' -%}
          {% render block %}
      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- if section.settings.newsletter_enable -%}
    <div class="hn-footer__newsletter">
      <hr class="hn-sep">
      <div class="hn-footer__newsletter-inner">
        {%- if section.settings.newsletter_heading != blank -%}
          <p class="hn-label hn-footer__newsletter-heading">{{ section.settings.newsletter_heading }}</p>
        {%- endif -%}
        {%- form 'customer', id: 'ContactFooter', class: 'hn-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="hn-footer__newsletter-field">
            <input
              id="NewsletterForm--{{ section.id }}"
              type="email"
              name="contact[email]"
              class="hn-footer__newsletter-input"
              value="{{ form.email }}"
              aria-required="true"
              autocomplete="email"
              placeholder="{{ 'newsletter.label' | t }}"
              required
            >
            <button type="submit" class="hn-footer__newsletter-btn" name="commit">
              Subscribe →
            </button>
          </div>
          {%- if form.posted_successfully? -%}
            <p class="hn-label hn-footer__newsletter-success">You're in.</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>
  {%- endif -%}

  <div class="hn-footer__bottom">
    <hr class="hn-sep">
    <div class="hn-footer__bottom-inner">
      <span class="hn-label-sm hn-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} Honchō Athletic
      </span>
      {%- if section.settings.payment_enable -%}
        <ul class="hn-footer__payment" role="list">
          {%- for type in shop.enabled_payment_types -%}
            <li>{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
      {%- if section.settings.show_policy -%}
        <ul class="hn-footer__policies">
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <li>
                <a href="{{ policy.url }}" class="hn-label-sm hn-footer__policy-link">{{ policy.title | escape }}</a>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "t:sections.footer.name",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.link_list.settings.heading.default",
          "label": "t:sections.footer.blocks.link_list.settings.heading.label"
        },
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "t:sections.footer.blocks.link_list.settings.menu.label"
        }
      ]
    },
    {
      "type": "brand_information",
      "name": "t:sections.footer.blocks.brand_information.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.footer.blocks.brand_information.settings.paragraph.content"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.brand_information.settings.show_social.label",
          "info": "t:sections.footer.blocks.brand_information.settings.show_social.info"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.footer.blocks.text.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "t:sections.footer.blocks.text.settings.heading.default",
          "label": "t:sections.footer.blocks.text.settings.heading.label"
        },
        {
          "type": "richtext",
          "id": "subtext",
          "default": "t:sections.footer.blocks.text.settings.subtext.default",
          "label": "t:sections.footer.blocks.text.settings.subtext.label"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 550,
          "step": 5,
          "unit": "px",
          "label": "Width",
          "default": 100
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            {
              "value": "",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__1.content",
      "info": "t:sections.footer.settings.header__1.info"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "default": true,
      "label": "t:sections.footer.settings.newsletter_enable.label"
    },
    {
      "type": "inline_richtext",
      "id": "newsletter_heading",
      "default": "t:sections.footer.settings.newsletter_heading.default",
      "label": "t:sections.footer.settings.newsletter_heading.label"
    },
    {
      "type": "header",
      "content": "t:sections.footer.settings.header__9.content"
    },
    {
      "type": "checkbox",
      "id": "enable_follow_on_shop",
      "default": true,
      "label": "t:sections.footer.settings.enable_follow_on_shop.label",
      "info": "t:sections.footer.settings.enable_follow_on_shop.info"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "default": true,
      "label": "t:sections.footer.settings.show_social.label",
      "info": "t:sections.footer.settings.show_social.info"
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "t:sections.footer.settings.enable_country_selector.label",
      "info": "t:sections.footer.settings.enable_country_selector.info"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "t:sections.footer.settings.enable_language_selector.label",
      "info": "t:sections.footer.settings.enable_language_selector.info"
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "default": true,
      "label": "t:sections.footer.settings.payment_enable.label"
    },
    {
      "type": "checkbox",
      "id": "show_policy",
      "default": true,
      "label": "t:sections.footer.settings.show_policy.label",
      "info": "t:sections.footer.settings.show_policy.info"
    },
    {
      "type": "header",
      "content": "t:sections.all.spacing"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.footer.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "link_list"
      },
      {
        "type": "text"
      }
    ]
  }
}
{% endschema %}
