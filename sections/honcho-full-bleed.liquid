<style>
  .hn-fullbleed {
    position: relative;
    margin-top: 120px;
    overflow: hidden;
  }

  .hn-fullbleed--dark {
    background: #000;
  }

  .hn-fullbleed__inner {
    position: relative;
    overflow: hidden;
  }

  .hn-fullbleed__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    inset: 0;
  }

  .hn-fullbleed__vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .hn-fullbleed__vignette--heavy {
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.28) 0%,
      transparent 25%,
      transparent 55%,
      rgba(0, 0, 0, 0.65) 100%
    );
  }

  .hn-fullbleed__vignette--light {
    background: linear-gradient(180deg, transparent 55%, rgba(0, 0, 0, 0.32) 100%);
  }

  .hn-fullbleed__meta-top {
    position: absolute;
    top: 20px;
    right: var(--page-gutter);
    z-index: 2;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    opacity: 0.75;
  }

  .hn-fullbleed__bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 var(--page-gutter) 56px;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 24px;
  }

  .hn-fullbleed__headline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 900;
    font-size: clamp(48px, 8.4vw, 150px);
    line-height: 0.88;
    letter-spacing: var(--tracking-display, -0.03em);
    color: #fff;
    text-shadow: 0 6px 40px rgba(0, 0, 0, 0.4);
    max-width: 70%;
  }

  .hn-fullbleed__headline-line2 {
    display: block;
  }

  .hn-fullbleed__headline-line2--green {
    color: var(--honcho-gold, #f5e1a8);
  }

  .hn-fullbleed__meta-bottom {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    opacity: 0.65;
    text-align: right;
    flex-shrink: 0;
    padding-bottom: 6px;
  }

  @media screen and (max-width: 749px) {
    .hn-fullbleed {
      margin-top: 72px;
    }

    .hn-fullbleed__headline {
      font-size: clamp(36px, 11vw, 72px);
      max-width: 100%;
    }

    .hn-fullbleed__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 12px;
      padding-bottom: 32px;
    }

    .hn-fullbleed__meta-bottom {
      text-align: left;
    }
  }
</style>

{%- assign vignette_class = 'hn-fullbleed__vignette--heavy' -%}
{%- if section.settings.vignette_type == 'light' -%}
  {%- assign vignette_class = 'hn-fullbleed__vignette--light' -%}
{%- endif -%}

<div class="hn-fullbleed{% if section.settings.dark_bg %} hn-fullbleed--dark{% endif %}">
  <div class="hn-fullbleed__inner" style="aspect-ratio: {{ section.settings.aspect_ratio | default: '16/9' }};">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 3000 | image_tag:
        class: 'hn-fullbleed__img',
        loading: 'lazy',
        widths: '750,1100,1500,2000,2800',
        sizes: '100vw',
        alt: section.settings.image.alt | default: section.settings.headline_line1 | default: shop.name
      }}
    {%- elsif section.settings.fallback_asset != blank -%}
      <img
        src="{{ section.settings.fallback_asset | asset_url }}"
        class="hn-fullbleed__img"
        loading="lazy"
        alt="{{ section.settings.headline_line1 | default: shop.name }}"
      >
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'hn-fullbleed__img placeholder-svg' }}
    {%- endif -%}

    <div class="hn-fullbleed__vignette {{ vignette_class }}"></div>

    {%- if section.settings.meta_right != blank -%}
      <div class="hn-fullbleed__meta-top">{{ section.settings.meta_right }}</div>
    {%- endif -%}

    {%- if section.settings.headline_line1 != blank or section.settings.headline_line2 != blank -%}
      <div class="hn-fullbleed__bottom hn-reveal">
        <div class="hn-fullbleed__headline">
          {{- section.settings.headline_line1 -}}
          {%- if section.settings.headline_line2 != blank -%}
            <span class="hn-fullbleed__headline-line2{% if section.settings.headline_line2_green %} hn-fullbleed__headline-line2--green{% endif %}">{{ section.settings.headline_line2 }}</span>
          {%- endif -%}
        </div>
        {%- if section.settings.meta_left != blank -%}
          <div class="hn-fullbleed__meta-bottom">{{ section.settings.meta_left }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Honchō Full Bleed",
  "tag": "section",
  "class": "honcho-full-bleed",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "fallback_asset",
      "label": "Fallback asset filename (e.g. shell.png)",
      "info": "Used as background image when no image is selected above. Enter the filename from your theme assets folder."
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "16/9", "label": "16:9 widescreen" },
        { "value": "4/3", "label": "4:3 classic" },
        { "value": "1000/536", "label": "1000:536 cinematic" },
        { "value": "21/9", "label": "21:9 ultra-wide" }
      ],
      "default": "16/9"
    },
    {
      "type": "select",
      "id": "vignette_type",
      "label": "Vignette",
      "options": [
        { "value": "heavy", "label": "Heavy" },
        { "value": "light", "label": "Light" }
      ],
      "default": "heavy"
    },
    {
      "type": "checkbox",
      "id": "dark_bg",
      "label": "Dark section background",
      "default": false
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "text",
      "id": "headline_line1",
      "label": "Line 1"
    },
    {
      "type": "text",
      "id": "headline_line2",
      "label": "Line 2"
    },
    {
      "type": "checkbox",
      "id": "headline_line2_green",
      "label": "Line 2 in green",
      "default": false
    },
    {
      "type": "header",
      "content": "Meta labels"
    },
    {
      "type": "text",
      "id": "meta_right",
      "label": "Top-right label"
    },
    {
      "type": "text",
      "id": "meta_left",
      "label": "Bottom-right label"
    }
  ],
  "presets": [
    {
      "name": "Honchō Full Bleed",
      "settings": {
        "aspect_ratio": "16/9",
        "vignette_type": "heavy",
        "headline_line1": "Built for",
        "headline_line2": "Competition."
      }
    }
  ]
}
{% endschema %}
