<style>
  .hn-about {
    padding: 80px var(--page-gutter) 120px;
  }

  .hn-about__intro {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 48px;
    align-items: start;
    padding-bottom: 80px;
    border-bottom: 1px solid #000;
    margin-bottom: 80px;
  }

  .hn-about__intro-label {
    opacity: 0.55;
    padding-top: 4px;
  }

  .hn-about__intro-body {
    font-size: 15px;
    line-height: 1.65;
    max-width: 680px;
  }

  .hn-about__story {
    display: grid;
    gap: 120px;
  }

  .hn-about__section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .hn-about__section--image-right .hn-about__section-media {
    order: 2;
  }

  .hn-about__section-number {
    opacity: 0.3;
    margin-bottom: 12px;
    display: block;
  }

  .hn-about__section-heading {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 900;
    font-size: clamp(36px, 5vw, 80px);
    line-height: 0.92;
    letter-spacing: var(--tracking-display, -0.03em);
    margin: 0 0 24px;
  }

  .hn-about__section-body {
    font-size: 14px;
    line-height: 1.65;
    max-width: 480px;
  }

  .hn-about__section-tagline {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 24px;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    border-bottom: 1px solid #000;
    padding-bottom: 2px;
  }

  /* Image treatments */
  .hn-about__polaroid {
    background: #fafaf7;
    padding: 18px 18px 60px;
    transform: rotate(-1.5deg);
    box-shadow: 0 20px 40px -20px rgba(0,0,0,0.25), 0 2px 6px rgba(0,0,0,0.08);
    position: relative;
    max-width: 440px;
  }

  .hn-about__polaroid::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 16px;
    background: rgba(255,200,0,0.7);
    z-index: 2;
  }

  .hn-about__polaroid-img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    display: block;
  }

  .hn-about__polaroid-caption {
    font-family: var(--font-cursive, 'Caveat', cursive);
    font-size: 18px;
    text-align: center;
    padding-top: 16px;
    display: block;
  }

  .hn-about__poster {
    background: #0b0b0b;
    transform: rotate(0.8deg);
    box-shadow: 0 20px 60px -30px rgba(0,0,0,0.45);
    position: relative;
    overflow: hidden;
    max-width: 440px;
  }

  .hn-about__poster-img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    display: block;
    opacity: 0.85;
  }

  .hn-about__collage {
    position: relative;
    height: 480px;
  }

  .hn-about__collage-item {
    position: absolute;
    width: 55%;
    overflow: hidden;
  }

  .hn-about__collage-item:nth-child(1) {
    top: 0; left: 0;
    transform: rotate(-3deg);
    z-index: 1;
  }

  .hn-about__collage-item:nth-child(2) {
    top: 40px; right: 0;
    transform: rotate(2deg);
    z-index: 2;
  }

  .hn-about__collage-item:nth-child(3) {
    bottom: 0; left: 10%;
    transform: rotate(-1deg);
    z-index: 3;
  }

  .hn-about__collage-item img {
    width: 100%;
    aspect-ratio: 4/5;
    object-fit: cover;
    display: block;
  }

  @media screen and (max-width: 989px) {
    .hn-about__intro {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .hn-about__section {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hn-about__section--image-right .hn-about__section-media {
      order: 0;
    }

    .hn-about__collage {
      height: 320px;
    }
  }
</style>

<div class="hn-about">

  {%- if section.settings.intro_label != blank or section.settings.intro_body != blank -%}
    <div class="hn-about__intro hn-reveal">
      <div>
        {%- if section.settings.intro_label != blank -%}
          <span class="hn-label hn-about__intro-label">{{ section.settings.intro_label }}</span>
        {%- endif -%}
      </div>
      <div class="hn-about__intro-body">
        {{ section.settings.intro_body }}
      </div>
    </div>
  {%- endif -%}

  <div class="hn-about__story">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'story_section' -%}
          {%- assign layout_class = '' -%}
          {%- if block.settings.layout == 'text-left' -%}
            {%- assign layout_class = 'hn-about__section--image-right' -%}
          {%- endif -%}
          <div class="hn-about__section {{ layout_class }} hn-reveal" {{ block.shopify_attributes }}>

            <div class="hn-about__section-content">
              {%- if block.settings.number != blank -%}
                <span class="hn-mono hn-about__section-number">{{ block.settings.number }}</span>
              {%- endif -%}
              {%- if block.settings.heading != blank -%}
                <h2 class="hn-about__section-heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <div class="hn-about__section-body">{{ block.settings.body }}</div>
              {%- endif -%}
              {%- if block.settings.tagline != blank -%}
                <a
                  href="{{ block.settings.tagline_link | default: '#' }}"
                  class="hn-about__section-tagline"
                >
                  {{ block.settings.tagline }} →
                </a>
              {%- endif -%}
            </div>

            <div class="hn-about__section-media">
              {%- case block.settings.image_treatment -%}
                {%- when 'polaroid' -%}
                  {%- if block.settings.image != blank -%}
                    <div class="hn-about__polaroid">
                      {{ block.settings.image | image_url: width: 900 | image_tag:
                        class: 'hn-about__polaroid-img',
                        loading: 'lazy',
                        widths: '400,600,900',
                        alt: block.settings.image.alt | default: block.settings.heading
                      }}
                      {%- if block.settings.caption != blank -%}
                        <span class="hn-about__polaroid-caption">{{ block.settings.caption }}</span>
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                {%- when 'poster' -%}
                  {%- if block.settings.image != blank -%}
                    <div class="hn-about__poster">
                      {{ block.settings.image | image_url: width: 900 | image_tag:
                        class: 'hn-about__poster-img',
                        loading: 'lazy',
                        widths: '400,600,900',
                        alt: block.settings.image.alt | default: block.settings.heading
                      }}
                    </div>
                  {%- endif -%}

                {%- when 'collage' -%}
                  <div class="hn-about__collage">
                    {%- if block.settings.image != blank -%}
                      <div class="hn-about__collage-item">
                        {{ block.settings.image | image_url: width: 600 | image_tag:
                          loading: 'lazy',
                          widths: '300,600',
                          alt: block.settings.image.alt | default: block.settings.heading
                        }}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.image_2 != blank -%}
                      <div class="hn-about__collage-item">
                        {{ block.settings.image_2 | image_url: width: 600 | image_tag:
                          loading: 'lazy',
                          widths: '300,600',
                          alt: block.settings.image_2.alt | default: block.settings.heading
                        }}
                      </div>
                    {%- endif -%}
                    {%- if block.settings.image_3 != blank -%}
                      <div class="hn-about__collage-item">
                        {{ block.settings.image_3 | image_url: width: 600 | image_tag:
                          loading: 'lazy',
                          widths: '300,600',
                          alt: block.settings.image_3.alt | default: block.settings.heading
                        }}
                      </div>
                    {%- endif -%}
                  </div>

                {%- else -%}
                  {%- if block.settings.image != blank -%}
                    <div style="aspect-ratio: 4/5; overflow: hidden;">
                      {{ block.settings.image | image_url: width: 900 | image_tag:
                        loading: 'lazy',
                        widths: '400,600,900',
                        style: 'width:100%;height:100%;object-fit:cover;',
                        alt: block.settings.image.alt | default: block.settings.heading
                      }}
                    </div>
                  {%- endif -%}
              {%- endcase -%}
            </div>

          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>

</div>

{% schema %}
{
  "name": "Honchō About",
  "tag": "section",
  "class": "honcho-about",
  "settings": [
    {
      "type": "text",
      "id": "intro_label",
      "label": "Intro label",
      "default": "01 — The Standard"
    },
    {
      "type": "richtext",
      "id": "intro_body",
      "label": "Intro body",
      "default": "<p>Honchō is not a lifestyle brand. It is a standard — a measurement of how you move, how you train, how you carry yourself when no one is watching.</p>"
    }
  ],
  "blocks": [
    {
      "type": "story_section",
      "name": "Story section",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Section number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Built for competition."
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text",
          "default": "<p>Every piece in the Honchō catalogue is made to move. Not to impress at the bar — to perform under pressure, to hold form under load, to earn its place in the rotation.</p>"
        },
        {
          "type": "text",
          "id": "tagline",
          "label": "Tagline / CTA text"
        },
        {
          "type": "url",
          "id": "tagline_link",
          "label": "Tagline link"
        },
        {
          "type": "select",
          "id": "layout",
          "label": "Layout",
          "options": [
            { "value": "image-left", "label": "Image left" },
            { "value": "text-left", "label": "Text left (image right)" }
          ],
          "default": "image-left"
        },
        {
          "type": "select",
          "id": "image_treatment",
          "label": "Image treatment",
          "options": [
            { "value": "plain", "label": "Plain" },
            { "value": "polaroid", "label": "Polaroid" },
            { "value": "poster", "label": "Poster" },
            { "value": "collage", "label": "Collage" }
          ],
          "default": "polaroid"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Polaroid caption"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Collage image 2"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Collage image 3"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Honchō About",
      "blocks": [
        {
          "type": "story_section",
          "settings": {
            "number": "01",
            "heading": "Built for competition.",
            "image_treatment": "polaroid",
            "layout": "image-left"
          }
        },
        {
          "type": "story_section",
          "settings": {
            "number": "02",
            "heading": "The mandate.",
            "image_treatment": "poster",
            "layout": "text-left"
          }
        }
      ]
    }
  ]
}
{% endschema %}
