<style>
  .hn-hero {
    position: relative;
    aspect-ratio: 4/3;
    max-height: 78vh;
    overflow: hidden;
    background: #111;
  }

  .hn-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hn-hero__vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0,0,0,0.35) 0%,
      transparent 22%,
      transparent 65%,
      rgba(0,0,0,0.55) 100%
    );
    z-index: 1;
    pointer-events: none;
  }

  .hn-hero__meta {
    position: absolute;
    top: 20px;
    left: var(--page-gutter);
    right: var(--page-gutter);
    display: flex;
    justify-content: space-between;
    align-items: center;
    z-index: 2;
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    mix-blend-mode: difference;
  }

  .hn-hero__bottom {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 0 var(--page-gutter) 56px;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: flex-end;
    gap: 24px;
  }

  .hn-hero__wordmark-img {
    width: min(78%, 1080px);
    height: auto;
    filter: brightness(0) invert(1) drop-shadow(0 8px 32px rgba(0,0,0,0.45));
    display: block;
  }

  .hn-hero__wordmark-text {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(48px, 9vw, 140px);
    line-height: 0.88;
    letter-spacing: var(--tracking-display);
    color: #fff;
    filter: drop-shadow(0 8px 32px rgba(0,0,0,0.45));
    display: block;
  }

  .hn-hero__cta-block {
    color: #fff;
    text-align: right;
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    line-height: 1.8;
    opacity: 0.9;
    flex-shrink: 0;
  }

  .hn-hero__cta-link {
    display: inline-block;
    margin-top: 10px;
    color: #fff;
    border-bottom: 1px solid #fff;
    padding-bottom: 2px;
    opacity: 0.9;
    transition: opacity var(--duration-fast) ease;
  }

  .hn-hero__cta-link:hover {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .hn-hero {
      aspect-ratio: 3/4;
      max-height: none;
    }

    .hn-hero__bottom {
      grid-template-columns: 1fr;
      padding-bottom: 36px;
    }

    .hn-hero__wordmark-img {
      width: min(88%, 500px);
    }

    .hn-hero__cta-block {
      text-align: left;
      font-size: 9px;
    }
  }
</style>

<div class="hn-hero">
  {%- if section.settings.image != blank -%}
    {{ section.settings.image | image_url: width: 2400 | image_tag:
      class: 'hn-hero__img',
      loading: 'eager',
      fetchpriority: 'high',
      widths: '750,1100,1500,1780,2000,2400',
      sizes: '100vw',
      alt: section.settings.image.alt | default: shop.name
    }}
  {%- else -%}
    <img
      src="{{ 'hero-shoot.jpg' | asset_url }}"
      class="hn-hero__img"
      loading="eager"
      fetchpriority="high"
      alt="{{ shop.name }}"
    >
  {%- endif -%}

  <div class="hn-hero__vignette"></div>

  <div class="hn-hero__meta hn-reveal" style="--animation-order: 1;">
    <div>
      {%- if section.settings.issue_number != blank -%}
        <div style="opacity:0.9;">{{ section.settings.issue_number }}</div>
      {%- endif -%}
      {%- if section.settings.batch_label != blank -%}
        <div style="opacity:0.6;margin-top:4px;">{{ section.settings.batch_label }}</div>
      {%- endif -%}
    </div>
    {%- if section.settings.photo_credit != blank -%}
      <div style="text-align:right;">
        <div style="opacity:0.9;">Cover Frame</div>
        <div style="opacity:0.6;margin-top:4px;">{{ section.settings.photo_credit }}</div>
      </div>
    {%- endif -%}
  </div>

  <div class="hn-hero__bottom hn-reveal" style="--animation-order: 2;">
    {%- if section.settings.wordmark != blank -%}
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {{ section.settings.wordmark | image_url: width: 1800 | image_tag:
          class: 'hn-hero__wordmark-img',
          alt: shop.name,
          loading: 'eager',
          widths: '400,800,1200,1800'
        }}
      </a>
    {%- else -%}
      <a href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        <img
          src="{{ 'honcho-lowercase.png' | asset_url }}"
          class="hn-hero__wordmark-img"
          alt="{{ shop.name }}"
          loading="eager"
        >
      </a>
    {%- endif -%}

    <div class="hn-hero__cta-block">
      Issued from Osaka<br>
      For the head of the pack<br>
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link | default: routes.collections_url }}" class="hn-hero__cta-link">
          {{ section.settings.cta_text }} →
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Honchō Hero",
  "tag": "section",
  "class": "honcho-hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "wordmark",
      "label": "Wordmark image (shown bottom-left)"
    },
    {
      "type": "text",
      "id": "issue_number",
      "label": "Issue number",
      "default": "ISSUE 002"
    },
    {
      "type": "text",
      "id": "batch_label",
      "label": "Batch label",
      "default": "Batch 02"
    },
    {
      "type": "text",
      "id": "photo_credit",
      "label": "Photo credit (top-right)",
      "default": "Photo: K. Okonkwo"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA button text",
      "default": "Shop the Issue"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    }
  ],
  "presets": [
    {
      "name": "Honchō Hero",
      "settings": {
        "issue_number": "ISSUE 002",
        "batch_label": "Batch 02",
        "photo_credit": "Photo: K. Okonkwo",
        "cta_text": "Shop the Issue"
      }
    }
  ]
}
{% endschema %}
